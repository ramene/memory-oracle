@inproceedings{thakur2021beir,
  author       = {Thakur, Nandan and Reimers, Nils and R{\"u}ckl{\'e}, Andreas and Srivastava, Abhishek and Gurevych, Iryna},
  title        = {{BEIR}: A Heterogeneous Benchmark for Zero-shot Evaluation of Information Retrieval Models},
  booktitle    = {Proceedings of the Neural Information Processing Systems Track on Datasets and Benchmarks (NeurIPS Datasets)},
  year         = {2021},
  note         = {Cross-domain IR benchmark spanning 18 datasets across fact-checking, biomedical QA, scientific retrieval, etc. Established the zero-shot evaluation discipline that exposed the brittleness of dense retrievers on out-of-distribution corpora; BM25 matches or beats most dense models on the majority of BEIR tasks. We cite it as the convention informing this section's metric design (nDCG@10, Recall@10 over the operationally-correct evaluation domain) rather than as a benchmark we test on directly.}
}

