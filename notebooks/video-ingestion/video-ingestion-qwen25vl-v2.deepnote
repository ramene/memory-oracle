          type: code
          content: >-
            # Manual env-vars for standalone UI runs. When triggered via Deepnote v2 API,

            # inputs are injected from declared input blocks and override these defaults.

            import os


            # Where Deepnote mounts uploaded files / Drive integration

            PROJECT_WORK = '/datasets/_deepnote_work/work'


            os.environ.setdefault('VIDEO_URL',          f'{PROJECT_WORK}/<your-video>.mp4')

            os.environ.setdefault('EXTRACT_MODE',       'both')

            os.environ.setdefault('CHUNK_DURATION_SEC', '600')      # 10 min chunks

            os.environ.setdefault('VIDEO_FPS',          '1.0')      # 1 frame per second sampled by Qwen

            os.environ.setdefault('VIDEO_MAX_PIXELS',   str(360*420))

            os.environ.setdefault('MODEL',              'Qwen/Qwen2.5-VL-7B-Instruct')

            os.environ.setdefault('PROMPT_PROFILE',     'trading-education')

            os.environ.setdefault('OUTPUT_PATH',        f'{PROJECT_WORK}/output.json')

            os.environ.setdefault('MAX_NEW_TOKENS',     '2048')

            os.environ.setdefault('WHISPER_MODEL',      'base')


            # HF token for faster model downloads + rate-limit avoidance

            # Either set HF_TOKEN via Deepnote integrations, or paste here for one-off runs.

            # os.environ['HF_TOKEN'] = 'hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'  # paste your HF token here for one-off runs (preferred: Deepnote project Env Vars)
          metadata:
            execution_start: 1780587065397
            execution_millis: 1
            execution_context_id: 406937cb-8df2-4c10-8336-c9df4da695ad
        - id: b2226426329c45c3b096468ab28f778e
          blockGroup: f8a8b9e49f114ff4b0a2d423e879df75
          sortingKey: "000012"
          outputs: []
          type: code
          content: |-
            # Install all deps unconditionally — Deepnote TensorFlow base image lacks several.
            # CRITICAL: qwen-vl-utils[decord]>=0.0.8 — decord is the fast video decoder; 0.0.8+
            # adds return_video_kwargs support needed for native video mode.
            # Two-step install:
            #   1) Regular deps INCLUDING decord (so the decord extra actually installs)
            #   2) --force-reinstall --no-deps on qwen-vl-utils to bypass any base-image upper
            #      bound (some sibling pin overrides --upgrade alone on TF base image)
            !apt-get update -qq && apt-get install -y -qq ffmpeg
            !pip install -q --upgrade yt-dlp 'transformers>=4.49' 'accelerate>=0.34' 'bitsandbytes>=0.43' decord pillow einops sentencepiece torchvision openai-whisper
            !pip install -q --force-reinstall --no-deps 'qwen-vl-utils>=0.0.8'

            # Verify — print version + signature + decord presence so we catch regressions early
            import qwen_vl_utils, inspect
            print(f'qwen-vl-utils version: {getattr(qwen_vl_utils, "__version__", "unknown")}')
            print(f'process_vision_info signature: {inspect.signature(qwen_vl_utils.process_vision_info)}')
            try:
                import decord
                print(f'decord: {decord.__version__} ✓ (fast video path)')
            except ImportError:
                print('decord: MISSING — video loading will fall back to slow per-frame ffmpeg')
          metadata:
            execution_start: 1780587065458
            execution_millis: 8180
            execution_context_id: 406937cb-8df2-4c10-8336-c9df4da695ad
