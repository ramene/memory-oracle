        - id: f83bd511f4bf41eaa3c0f541acb89aa3
          blockGroup: 429b29cf984c4d16a32734c9e64b2f69
          sortingKey: "000025"
          outputs: []
          type: code
          content: |-
            # §6 — per-chunk native-video inference (defensive against qwen-vl-utils version drift)
            # Force decord backend BEFORE process_vision_info import — torchvision fallback is broken
            # in torch>=2.0 (torchvision.io.read_video removed). decord is the fast, stable path.
            import os
            os.environ.setdefault('FORCE_QWENVL_VIDEO_READER', 'decord')

            try:
                import decord  # noqa: F401 — required by qwen-vl-utils video backend
            except ImportError:
                import subprocess, sys
                subprocess.run([sys.executable, '-m', 'pip', 'install', '-q', 'decord'], check=True)
                import decord  # noqa: F401

            from qwen_vl_utils import process_vision_info
            import inspect

            _PVI_SIG = inspect.signature(process_vision_info)
            _HAS_VIDEO_KWARGS = 'return_video_kwargs' in _PVI_SIG.parameters
            print(f'video backend: {os.environ.get("FORCE_QWENVL_VIDEO_READER", "auto")}, decord: {decord.__version__}')
            print(f'process_vision_info supports return_video_kwargs: {_HAS_VIDEO_KWARGS}')


            def _normalize_video_kwargs(vk):
                """transformers 5.x uses StrictDataclass validation that rejects list-wrapped
                scalars. qwen-vl-utils 0.0.8+ returns video_kwargs with list-per-video shape
                (e.g. {'fps': [1.0]}). When there's only one video per call, unwrap scalars
                so the processor's dataclass validation passes."""
                if not isinstance(vk, dict):
                    return vk
                for key in ('fps',):
                    v = vk.get(key)
                    if isinstance(v, list) and len(v) == 1:
                        vk[key] = v[0]
                return vk


            def _infer_chunk(chunk_path):
                messages = [{
                    'role': 'user',
                    'content': [
                        {'type': 'video', 'video': f'file://{chunk_path}',
                         'max_pixels': VIDEO_MAX_PIXELS, 'fps': VIDEO_FPS},
                        {'type': 'text', 'text': PROMPT},
                    ],
                }]
                text = vl_processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)

                # Two distinct API paths — fps source differs to avoid duplicate kwarg
                if _HAS_VIDEO_KWARGS:
                    # NEW path: video_kwargs carries fps (list-wrapped); unwrap, do NOT pass fps explicitly
                    image_inputs, video_inputs, video_kwargs = process_vision_info(
                        messages, return_video_kwargs=True
                    )
                    video_kwargs = _normalize_video_kwargs(video_kwargs)
                    inputs = vl_processor(
                        text=[text],
                        images=image_inputs,
                        videos=video_inputs,
                        padding=True,
                        return_tensors='pt',
                        **video_kwargs,
                    ).to(DEVICE)
                else:
                    # LEGACY path: video_kwargs absent or empty; pass fps explicitly
                    result = process_vision_info(messages)
                    if len(result) == 3:
                        image_inputs, video_inputs, video_kwargs = result
                        video_kwargs = _normalize_video_kwargs(video_kwargs)
                    else:
                        image_inputs, video_inputs = result
                        video_kwargs = {}
                    inputs = vl_processor(
                        text=[text],
                        images=image_inputs,
                        videos=video_inputs,
                        fps=VIDEO_FPS,
                        padding=True,
                        return_tensors='pt',
                        **video_kwargs,
                    ).to(DEVICE)

                with torch.no_grad():
                    generated_ids = vl_model.generate(**inputs, max_new_tokens=MAX_NEW_TOKENS)
                trimmed = [out[len(inp):] for inp, out in zip(inputs.input_ids, generated_ids)]
                output_text = vl_processor.batch_decode(trimmed, skip_special_tokens=True,
                                                          clean_up_tokenization_spaces=False)[0]
                cleaned = re.sub(r'^```(?:json)?\s*|\s*```$', '', output_text.strip(), flags=re.MULTILINE).strip()
                try:
                    return json.loads(cleaned)
                except json.JSONDecodeError as e:
                    return {'_parse_error': str(e), '_raw_output': output_text}

            chunk_signals = []
            if vl_model is not None:
                print(f'Inferring {len(chunk_records)} chunks (fps={VIDEO_FPS}, max_pixels={VIDEO_MAX_PIXELS})...')
                t0 = time.time()
                for cr in chunk_records:
                    cr_t0 = time.time()
                    try:
                        sig = _infer_chunk(cr['path'])
                    except Exception as e:
                        sig = {'_inference_error': f'{type(e).__name__}: {e}'}
                    chunk_signals.append({
                        'chunk_idx': cr['chunk_idx'],
                        'start_sec': cr['start_sec'],
                        'end_sec': cr['end_sec'],
                        'inference_sec': round(time.time() - cr_t0, 2),
                        'signal': sig,
                    })
                    elapsed = time.time() - cr_t0
                    has_error = isinstance(sig, dict) and any(k.startswith('_') and 'error' in k for k in sig)
                    status = 'ERROR' if has_error else 'OK'
                    print(f'  chunk {cr["chunk_idx"]+1}/{len(chunk_records)} ({cr["start_sec"]:.0f}-{cr["end_sec"]:.0f}s) {status} in {elapsed:.1f}s')
                print(f'Inference complete: {len(chunk_signals)} chunks in {time.time()-t0:.1f}s')
            else:
                print('VL model not loaded (EXTRACT_MODE=transcript) - chunk_signals empty')
          metadata:
            execution_start: 1780587178048
            execution_millis: 0
            execution_context_id: 406937cb-8df2-4c10-8336-c9df4da695ad
        - id: a1eeffad36a54a489437e13e9653063b
          blockGroup: dfea1be59b004f59842e497e6d5a2494
          sortingKey: "000026"
          type: markdown
          content: >-
            ## §7 Transcript — sidecar OR Whisper fallback


            If `SUBS_PATH` (set in §3) exists, parse it. Otherwise run Whisper locally on

            the full video — works for local files (no YouTube auth needed). Whisper

            model size is configurable (`base` default; `large-v3` for max quality).
          metadata: {}
        - id: c651552b7b374f7281de0628c37edcd6
          blockGroup: 23e5e03e198047fbbdc55968966fe95a
          sortingKey: "000027"
          contentHash: 52ed3fda
          executionCount: 21
          executionFinishedAt: 2026-06-04T15:34:59.424000Z
          executionStartedAt: 2026-06-04T15:32:58.107000Z
          outputs:
            - name: stdout
              text: >+
                No sidecar - running Whisper (base model) on BRUlSm4gdQ4.mp4...

                100%|████████████████████████████████████████| 139M/139M [00:00<00:00, 494MiB/s]

                Detected language: English
                 99%|█████████▉| 438569/441569 [01:47<00:00, 4096.93frames/s]  Whisper: 405 segments, 54076 chars in 120.5s

              output_type: stream
          type: code
          content: >-
            # §7 — transcript extraction (sidecar OR Whisper)

            transcript_text = ''

            transcript_segments = []


            if EXTRACT_MODE in ('transcript', 'both'):
                if SUBS_PATH and SUBS_PATH.exists():
                    raw = SUBS_PATH.read_text(errors='replace')
                    suffix = SUBS_PATH.suffix.lower()
                    if suffix == '.vtt' or '.vtt' in SUBS_PATH.name:
                        block_re = re.compile(
                            r'(\d{2}:\d{2}:\d{2}\.\d{3})\s*-->\s*(\d{2}:\d{2}:\d{2}\.\d{3})[^\n]*\n(.*?)(?=\n\n|\Z)',
                            re.DOTALL
                        )
                        def _ts_to_sec(s):
                            h, m, rest = s.split(':')
                            return int(h)*3600 + int(m)*60 + float(rest)
                        for m in block_re.finditer(raw):
                            seg_text = re.sub(r'<[^>]+>', '', m.group(3)).strip().replace('\n', ' ')
                            if seg_text:
                                transcript_segments.append({
                                    'start_sec': _ts_to_sec(m.group(1)),
                                    'end_sec': _ts_to_sec(m.group(2)),
                                    'text': seg_text,
                                })
                                transcript_text += seg_text + ' '
                    # SRT path similar but operators rarely use SRT - skip for brevity
                    transcript_text = transcript_text.strip()
                    print(f'sidecar transcript: {len(transcript_segments)} segments, {len(transcript_text)} chars')
                else:
                    # Whisper fallback
                    try:
                        import whisper
                    except ImportError:
                        _pip('openai-whisper')
                        import whisper
                    print(f'No sidecar - running Whisper ({WHISPER_MODEL_SIZE} model) on {VIDEO_PATH.name}...')
                    t0 = time.time()
                    whisper_model = whisper.load_model(WHISPER_MODEL_SIZE)
                    result = whisper_model.transcribe(str(VIDEO_PATH), verbose=False)
                    transcript_text = result['text'].strip()
                    transcript_segments = [
                        {'start_sec': seg['start'], 'end_sec': seg['end'], 'text': seg['text'].strip()}
                        for seg in result.get('segments', [])
                    ]
                    print(f'  Whisper: {len(transcript_segments)} segments, {len(transcript_text)} chars in {time.time()-t0:.1f}s')
            else:
                print('EXTRACT_MODE excludes transcript - skipping')
          metadata:
            execution_start: 1780587178107
            execution_millis: 121317
            execution_context_id: 406937cb-8df2-4c10-8336-c9df4da695ad
        - id: ee0cb4d3a40c42888670475b3bbfd7f0
          blockGroup: 46254d7e928f422f9a92e02030dae564
          sortingKey: "000028"
          type: markdown
          content: >-
            ## §8 Aggregate — merge per-chunk outputs with provenance


            Each item in each chunk's signal lists gets tagged with `_chunk_idx` +

            `_chunk_start_sec` so downstream lesson-card drafting can trace any claim

            back to the exact video timestamp where it originated.
          metadata: {}
        - id: bc8a00d1b60444de9e158feb94f9e4f8
          blockGroup: d5024f9a609e4d309763367732a74dbd
          sortingKey: "000029"
          contentHash: b3e88b23
          executionCount: 22
          executionFinishedAt: 2026-06-04T15:34:59.478000Z
          executionStartedAt: 2026-06-04T15:34:59.478000Z
          outputs: []
          type: code
          content: |-
            # §8 — aggregate (schema-agnostic) with provenance tagging
            # Collects EVERY field from every chunk's signal dict regardless of profile
            # schema. Replaces the previous hardcoded trading-education _FIELD_MAP which
            # silently emptied for any other profile (e.g. ai-systems-research run on
            # AlphaProof Nexus where per-chunk signal was rich but aggregate was hollow).
            #
            # Each aggregated entry carries _chunk_idx + _chunk_start_sec provenance:
            #   - list-valued chunk fields  → append each item with provenance tags
            #   - scalar/dict-valued fields → wrap as {value: ..., _chunk_idx, _chunk_start_sec}
            #   - fields starting with '_'  → skipped (error markers like _inference_error)
            #   - empty values              → skipped (no noise in the aggregate)
            #
            # Always-emitted keys: segment_count, segments_with_signal, fields_observed.
            # All other keys reflect whatever the active prompt profile produced.

            from collections import defaultdict

            agg = {
                'segment_count':        len(chunk_signals),
                'segments_with_signal': sum(
                    1 for cs in chunk_signals
                    if isinstance(cs.get('signal'), dict)
                    and not any(k.startswith('_') for k in cs['signal'])
                ),
                'fields_observed':      [],
            }

            _collected = defaultdict(list)

            for cs in chunk_signals:
                sig = cs.get('signal', {})
                if not isinstance(sig, dict):
                    continue
                if any(k.startswith('_') for k in sig):
                    continue

                prov = {'_chunk_idx': cs['chunk_idx'], '_chunk_start_sec': cs['start_sec']}

                for field_name, value in sig.items():
                    if field_name.startswith('_'):
                        continue
                    if value is None or value == '' or value == [] or value == {}:
                        continue
                    if isinstance(value, list):
                        for item in value:
                            entry = dict(item) if isinstance(item, dict) else {'value': item}
                            entry.update(prov)
                            _collected[field_name].append(entry)
                    else:
                        _collected[field_name].append({'value': value, **prov})

            for field_name, items in _collected.items():
                agg[field_name] = items
            agg['fields_observed'] = sorted(_collected.keys())

            print(f'Aggregate: {agg["segments_with_signal"]}/{len(chunk_signals)} chunks contributed signal')
            print(f'  fields observed ({len(agg["fields_observed"])}):')
            for k in agg['fields_observed']:
                print(f'    {k}: {len(_collected[k])}')
          metadata:
            execution_start: 1780587299478
            execution_millis: 0
            execution_context_id: 406937cb-8df2-4c10-8336-c9df4da695ad
